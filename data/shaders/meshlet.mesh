#version 460

#extension GL_EXT_mesh_shader : require
#extension GL_EXT_buffer_reference : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_GOOGLE_include_directive : enable

#include "common.glsl"

layout(local_size_x = 128, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 124) out;

layout(location = 0) out vec3 out_normal[];
layout(location = 1) out vec2 out_uv[];
layout(location = 2) out vec3 out_meshlet_color[];
layout(location = 3) flat out uint out_albedo_index[];
layout(location = 4) flat out uint out_normals_index[];
layout(location = 5) flat out uint out_material_index[];
layout(location = 6) out vec3 out_world_pos[];

taskPayloadSharedEXT MeshletTaskPayload payload;

layout(set = 0, binding = 0) uniform UBO {
    SceneUBO scene;
};

layout(scalar, set = 1, binding = 0) readonly buffer DrawDataBuffer {
    DrawData draw_data[];
} uniforms;

layout(scalar, set = 1, binding = 1) readonly buffer MeshDrawCommands {
    uint culled_count;
    MeshDrawCommand cmds[];
} draw_commands;

layout(scalar, set = 2, binding = 0) readonly buffer IndexBuffer {
    uint indices[];
} global_indices;

layout(scalar, set = 2, binding = 1) readonly buffer VertexBuffer {
    Vertex vertices[];
} global_vertices;

layout(scalar, set = 2, binding = 2) readonly buffer MeshletBuffer {
    Meshlet meshlets[];
} meshlets;

layout(scalar, set = 2, binding = 3) readonly buffer MeshletBoundsBuffer {
    MeshletBounds bounds[];
} meshlet_bounds;

layout(scalar, set = 2, binding = 4) readonly buffer MeshletVertexIndices {
    uint indices[];
} meshlet_vertex_indices;

layout(scalar, set = 2, binding = 5) readonly buffer MeshletPrimitiveIndices {
    uint8_t indices[];
} meshlet_primitive_indices;

layout(push_constant, std430) uniform push {
    vec2 screen_size;

    uint disable_frustum_cull;
    uint disable_depth_cull;
    uint disable_cone_cull;
    uint disable_small_triangle_cull;
} pc;

shared vec3 vertex_clip[64];

void main() {
    uint local_meshlet_id = payload.meshlet_indices[gl_WorkGroupID.x];
    uint thread_id = gl_LocalInvocationIndex;

    uint meshlet_id = payload.meshlet_offset + local_meshlet_id;

    DrawData draw = uniforms.draw_data[payload.draw_id];

    uint draw_meshlet_id = draw.meshlet_offset + meshlet_id;
    Meshlet m = meshlets.meshlets[draw_meshlet_id];

    SetMeshOutputsEXT(m.vertex_count, m.triangle_count);

    if (thread_id < m.vertex_count) {
        uint global_vertex_index = meshlet_vertex_indices.indices[m.vertex_offset + thread_id];

        uint base = global_vertex_index;
        Vertex vertex = global_vertices.vertices[base];

        // uint hash = draw_meshlet_id * 747796405u + 2891336453u;
        // vec3 meshlet_color = vec3(
        //         float((hash >> 0) & 0xFF) / 255.0,
        //         float((hash >> 8) & 0xFF) / 255.0,
        //         float((hash >> 16) & 0xFF) / 255.0
        //     );
        vec3 meshlet_color = vec3(1.0);

        vec3 world_pos = rotate_quat(vertex.position, draw.rotation) * draw.scale + draw.position;
        vec4 clip = scene.proj * (scene.view * vec4(world_pos, 1.0));

        gl_MeshVerticesEXT[thread_id].gl_Position = scene.view_proj * vec4(world_pos, 1.0);
        out_normal[thread_id] = rotate_quat(vertex.normal, draw.rotation);
        out_uv[thread_id] = vertex.uv;
        out_meshlet_color[thread_id] = meshlet_color;
        out_albedo_index[thread_id] = draw.albedo_index;
        out_normals_index[thread_id] = draw.normals_index;
        out_material_index[thread_id] = draw.material_index;
        out_world_pos[thread_id] = world_pos.xyz;

        vertex_clip[thread_id] = vec3((clip.xy / clip.w * 0.5 + vec2(0.5)) * pc.screen_size, clip.w);
    }

    barrier();

    if (thread_id < m.triangle_count) {
        uint prim_base = m.triangle_offset + thread_id * 3;

        uint i_0 = uint(meshlet_primitive_indices.indices[prim_base + 0]);
        uint i_1 = uint(meshlet_primitive_indices.indices[prim_base + 1]);
        uint i_2 = uint(meshlet_primitive_indices.indices[prim_base + 2]);

        gl_PrimitiveTriangleIndicesEXT[thread_id] = uvec3(i_0, i_1, i_2);

        if (scene.disable_culling == 0 && pc.disable_small_triangle_cull == 0) {
            bool culled = false;

            vec2 pa = vertex_clip[i_0].xy;
            vec2 pb = vertex_clip[i_1].xy;
            vec2 pc = vertex_clip[i_2].xy;

            vec2 eb = pb - pa;
            vec2 ec = pc - pa;

            culled = culled || (eb.x * ec.y <= eb.y * ec.x);

            vec2 bmin = min(pa, min(pb, pc));
            vec2 bmax = max(pa, max(pb, pc));
            float sbprec = 1.0 / 256.0;

            culled = culled || (round(bmin.x - sbprec) == round(bmax.x) || round(bmin.y) == round(bmax.y + sbprec));
            culled = culled && (vertex_clip[i_0].z > 0 && vertex_clip[i_1].z > 0 && vertex_clip[i_2].z > 0);

            gl_MeshPrimitivesEXT[thread_id].gl_CullPrimitiveEXT = culled;
        }
    }
}
